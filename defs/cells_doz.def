# ---- Duodecimal NOT: complement ----
# NOT(A) = 11 - A
# The scribal negation. Turn the tablet over.
# 0 ↔ 11, 1 ↔ 10, 2 ↔ 9, 3 ↔ 8, 4 ↔ 7, 5 ↔ 6

cell NOT radix 12 inputs 1 outputs 1
  pin A in
  pin Y out 11-A
  truth  0 -> 11
  truth  1 -> 10
  truth  2 ->  9
  truth  3 ->  8
  truth  4 ->  7
  truth  5 ->  6
  truth  6 ->  5
  truth  7 ->  4
  truth  8 ->  3
  truth  9 ->  2
  truth 10 ->  1
  truth 11 ->  0
end

# ---- Duodecimal MUX: 12-way select ----
# ONE control digit selects from TWELVE inputs.
# Binary needs 4 bits for this. Duodecimal does it
# with one wire. This is why the Sumerians ruled
# Mesopotamia and we're still using their time system.
#
# Shamash, god of the sun, had 12 rays.
# This MUX has 12 data inputs.
# Coincidence? The Anunnaki think not.
#
# (Full 12×12 truth table omitted for sanity.
# The pattern: sel=N → output = D_N)

cell MUX radix 12 inputs 2 outputs 1
  pin S in
  pin D in
  pin Y out sel(S,D)
  truth  0  0 ->  0
  truth  0  1 ->  0
