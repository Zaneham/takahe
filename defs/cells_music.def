# cells_music.def -- Chromatic music theory cells (radix-12)
#
# The chromatic scale is radix-12. Every operation in
# Western music theory is modular arithmetic mod 12.
# Transposition is addition. Inversion is subtraction from 12.
# A major chord is a lookup table.
#
# Pitch classes:
#   0=C, 1=C#, 2=D, 3=D#, 4=E, 5=F,
#   6=F#, 7=G, 8=G#, 9=A, 10=A#, 11=B
#
# Intervals:
#   0=unison, 1=m2, 2=M2, 3=m3, 4=M3, 5=P4,
#   6=tritone, 7=P5, 8=m6, 9=M6, 10=m7, 11=M7
#
# Bach would have loved this. He WAS this.
# The Well-Tempered Clavier is a proof that all 12 keys
# are equivalent under transposition — which is to say,
# modular addition is commutative. He proved group theory
# with a harpsichord 100 years before Galois.

# ---- TRANSPOSE: add interval mod 12 ----
# Move a pitch up by an interval. The fundamental operation
# of music. Every key change, every sequence, every
# modulation is this gate repeated.

cell TRANSPOSE radix 12 inputs 2 outputs 1
  pin NOTE in
  pin INTERVAL in
  pin Y out (NOTE+INTERVAL)%12
  truth  0  0 ->  0
  truth  0  1 ->  1
  truth  0  2 ->  2
  truth  0  3 ->  3
  truth  0  4 ->  4
  truth  0  5 ->  5
  truth  0  6 ->  6
  truth  0  7 ->  7
  truth  0  8 ->  8
  truth  0  9 ->  9
  truth  0 10 -> 10
  truth  0 11 -> 11
  truth  1  0 ->  1
  truth  1  1 ->  2
  truth  1  2 ->  3
  truth  1  3 ->  4
  truth  1  4 ->  5
  truth  1  5 ->  6
  truth  1  6 ->  7
  truth  1  7 ->  8
  truth  1  8 ->  9
  truth  1  9 -> 10
  truth  1 10 -> 11
  truth  1 11 ->  0
  truth  2  0 ->  2
  truth  2  1 ->  3
  truth  2  2 ->  4
  truth  2  3 ->  5
  truth  2  4 ->  6
  truth  2  5 ->  7
  truth  2  6 ->  8
  truth  2  7 ->  9
