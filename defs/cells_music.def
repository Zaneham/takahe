# ---- INVERT: pitch class inversion (12 - note) mod 12 ----
# Mirror a melody around C. Used in twelve-tone serialism
# (Schoenberg, 1923) and fugal inversion (Bach, 1722).

cell INVERT radix 12 inputs 1 outputs 1
  pin NOTE in
  pin Y out (12-NOTE)%12
  truth  0 ->  0
  truth  1 -> 11
  truth  2 -> 10
  truth  3 ->  9
  truth  4 ->  8
  truth  5 ->  7
  truth  6 ->  6
  truth  7 ->  5
  truth  8 ->  4
  truth  9 ->  3
  truth 10 ->  2
  truth 11 ->  1
end

# ---- INTERVAL: distance between two notes ----
# (B - A + 12) mod 12. How far apart are they?
# Same truth table as TRANSPOSE but semantically different:
# TRANSPOSE moves, INTERVAL measures.

cell INTERVAL radix 12 inputs 2 outputs 1
  pin A in
  pin B in
  pin Y out (B-A+12)%12
  truth  0  0 ->  0
  truth  0  1 ->  1
  truth  0  2 ->  2
  truth  0  3 ->  3
  truth  0  4 ->  4
  truth  0  5 ->  5
