# ---- CONSONANCE: interval → consonance rating ----
# Maps an interval to its perceived consonance.
# Based on frequency ratios and 2,500 years of music theory.
#   0 (unison)  → 11 (perfect)
#   7 (P5)      → 10 (perfect)
#   5 (P4)      →  9 (perfect)
#   4 (M3)      →  7 (imperfect consonance)
#   3 (m3)      →  6 (imperfect consonance)
#   9 (M6)      →  5
#   8 (m6)      →  4
#   2 (M2)      →  2 (mild dissonance)
#   10 (m7)     →  2
#   11 (M7)     →  1 (harsh dissonance)
#   1 (m2)      →  0 (maximum dissonance)
#   6 (tritone) →  0 (diabolus in musica)
#
# Pythagoras worked this out with a monochord.
# We worked it out with a truth table.
# Same answer. Different vibes.

cell CONSONANCE radix 12 inputs 1 outputs 1
  pin INTERVAL in
  pin RATING out consonance(INTERVAL)
  truth  0 -> 11
  truth  1 ->  0
  truth  2 ->  2
  truth  3 ->  6
  truth  4 ->  7
  truth  5 ->  9
  truth  6 ->  0
  truth  7 -> 10
  truth  8 ->  4
  truth  9 ->  5
  truth 10 ->  2
  truth 11 ->  1
end

# ---- Music DFF and CONST ----

cell DFF radix 12 inputs 1 outputs 1
  pin D in
  pin Q out D
  truth  0 ->  0
  truth  1 ->  1
  truth  2 ->  2
  truth  3 ->  3
  truth  4 ->  4
  truth  5 ->  5
  truth  6 ->  6
  truth  7 ->  7
  truth  8 ->  8
  truth  9 ->  9
  truth 10 -> 10
  truth 11 -> 11
end

cell CONST radix 12 inputs 0 outputs 1
  pin Y out
  truth ->  0
  truth ->  1
  truth ->  2
  truth ->  3
  truth ->  4
  truth ->  5
  truth ->  6
  truth ->  7
  truth ->  8
  truth ->  9
  truth -> 10
  truth -> 11
end

# "Music is the pleasure the human mind experiences from
# counting without being aware that it is counting."
#   — Leibniz (who also recognised the I Ching as binary)
#
# He was right about that too. Music IS counting mod 12.
# And now it's a .def file.
