# cells_quark.def -- Quark flavour logic (radix-6)
#
# The Standard Model's selection rules as truth tables.
#
# Six quark flavours:
#   0 = UP       charge +2/3, mass ~2 MeV
#   1 = DOWN     charge -1/3, mass ~5 MeV
#   2 = CHARM    charge +2/3, mass ~1.3 GeV
#   3 = STRANGE  charge -1/3, mass ~95 MeV
#   4 = TOP      charge +2/3, mass ~173 GeV
#   5 = BOTTOM   charge -1/3, mass ~4.2 GeV
#
# Three generations: (up,down), (charm,strange), (top,bottom)
# Each generation is heavier than the last. Nobody knows why.
# The universe has design choices that make less sense than
# most legacy codebases.
#
# Antimatter IS the NOT gate: every quark has an antiquark
# with opposite charge. Charge conjugation is complement
# within a generation. The universe invented CMOS.

# ---- CHARGE: quark → charge class ----
# 0 = charge +2/3 (up-type: up, charm, top)
# 1 = charge -1/3 (down-type: down, strange, bottom)

cell CHARGE radix 6 inputs 1 outputs 1
  pin Q in
  pin C out charge(Q)
  truth 0 -> 0
  truth 1 -> 1
  truth 2 -> 0
  truth 3 -> 1
  truth 4 -> 0
  truth 5 -> 1
end

# ---- GENERATION: which generation? ----
# 0 = first (up, down)     — stable matter
# 1 = second (charm, strange) — cosmic rays
# 2 = third (top, bottom)  — only in colliders

cell GENERATION radix 6 inputs 1 outputs 1
  pin Q in
  pin G out gen(Q)
  truth 0 -> 0
  truth 1 -> 0
  truth 2 -> 1
  truth 3 -> 1
  truth 4 -> 2
  truth 5 -> 2
end

# ---- ANTIQUARK: charge conjugation ----
# Swap up↔down within each generation.
# Antimatter. The NOT gate of particle physics.
# Every particle has an antiparticle. Every bit has
# a complement. The symmetry runs deep.

cell NOT radix 6 inputs 1 outputs 1
  pin Q in
  pin QBAR out conjugate(Q)
  truth 0 -> 1
  truth 1 -> 0
  truth 2 -> 3
  truth 3 -> 2
  truth 4 -> 5
  truth 5 -> 4
end

# ---- BARYON: are these three quarks a valid baryon? ----
# A baryon requires one red + one green + one blue quark
# (colour confinement). We simplify: a valid baryon has
# net charge that's an integer (0 or +1 for common baryons).
#
# Proton  = up + up + down    = +2/3 + 2/3 - 1/3 = +1 ✓
# Neutron = up + down + down  = +2/3 - 1/3 - 1/3 =  0 ✓
#
# Output: 1 = valid baryon (integer charge), 0 = not
# For this to be valid: need exactly 1 or 2 up-type quarks
# (the rest are down-type). Three up-types gives +2 (Delta++)
# which IS valid. Zero up-types gives -1 (Delta-) also valid.
# Actually ALL combinations of 3 quarks satisfy colour if
# you have all three colours. We check flavour plausibility:
# output the net charge class (0, 1, 2, 3, 4, 5 → mapped
# to thirds: 0/3, 1/3, 2/3, 3/3, 4/3, 5/3).
# Integer charge (0 or 3) = common baryon.

cell BARYON radix 6 inputs 3 outputs 1
  pin Q1 in
  pin Q2 in
  pin Q3 in
  pin VALID out baryon(Q1,Q2,Q3)
  # Proton: u u d (0,0,1) → charge 2/3+2/3-1/3 = 1 → valid(1)
  truth 0 0 1 -> 1
  truth 0 1 0 -> 1
  truth 1 0 0 -> 1
  # Neutron: u d d (0,1,1) → charge 2/3-1/3-1/3 = 0 → valid(1)
  truth 0 1 1 -> 1
  truth 1 0 1 -> 1
  truth 1 1 0 -> 1
  # Delta++: u u u (0,0,0) → charge +2 → valid(1)
  truth 0 0 0 -> 1
  # Delta-: d d d (1,1,1) → charge -1 → valid(1)
  truth 1 1 1 -> 1
  # Sigma+: u u s (0,0,3) → charge +1 → valid(1)
  truth 0 0 3 -> 1
  truth 0 3 0 -> 1
  truth 3 0 0 -> 1
  # Lambda: u d s (0,1,3) → charge 0 → valid(1)
  truth 0 1 3 -> 1
  truth 0 3 1 -> 1
  truth 1 0 3 -> 1
  truth 1 3 0 -> 1
  truth 3 0 1 -> 1
  truth 3 1 0 -> 1
  # Sigma-: d d s → charge -1 → valid(1)
  truth 1 1 3 -> 1
  truth 1 3 1 -> 1
  truth 3 1 1 -> 1
  # Xi0: u s s → charge 0 → valid
  truth 0 3 3 -> 1
  truth 3 0 3 -> 1
  truth 3 3 0 -> 1
  # Xi-: d s s → charge -1 → valid
  truth 1 3 3 -> 1
  truth 3 1 3 -> 1
  truth 3 3 1 -> 1
  # Omega-: s s s → charge -1 → valid
  truth 3 3 3 -> 1
  # Everything with charm/top/bottom is exotic but valid
  # (simplified: all combinations are physically possible
  # with right colour assignment, output 1 for all)
  truth 0 0 2 -> 1
  truth 0 2 0 -> 1
  truth 2 0 0 -> 1
  truth 2 2 2 -> 1
  truth 4 4 4 -> 1
  truth 5 5 5 -> 1
  truth 0 0 4 -> 1
  truth 0 4 0 -> 1
  truth 4 0 0 -> 1
  truth 0 0 5 -> 1
  truth 0 5 0 -> 1
  truth 5 0 0 -> 1
end

# ---- Quark DFF ----

cell DFF radix 6 inputs 1 outputs 1
  pin D in
  pin Q out D
  truth 0 -> 0
  truth 1 -> 1
  truth 2 -> 2
  truth 3 -> 3
  truth 4 -> 4
  truth 5 -> 5
end

# ---- Quark CONST ----

cell CONST radix 6 inputs 0 outputs 1
  pin Y out
  truth -> 0
  truth -> 1
  truth -> 2
  truth -> 3
  truth -> 4
  truth -> 5
end

# Murray Gell-Mann named quarks after a line in
# Finnegans Wake: "Three quarks for Muster Mark!"
# He won the Nobel Prize for organising them.
#
# We organised them into a .def file.
# The Nobel committee has not yet responded to our
# nomination. We assume the letter was lost.
